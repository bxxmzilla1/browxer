# ── Browserless ──────────────────────────────────────────────────────────────
# Self-hosted (Docker): ws://localhost:3000
# Browserless cloud:    wss://chrome.browserless.io
BROWSERLESS_WS_URL=ws://localhost:3000

# Leave blank for a self-hosted instance with no token configured
BROWSERLESS_TOKEN=

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000

# How long a session can sit idle before being reaped (ms). Default: 30 min.
IDLE_TIMEOUT_MS=1800000

# How often to persist cookies/storage to Supabase (ms). Default: 30 s.
PERSIST_INTERVAL_MS=30000
